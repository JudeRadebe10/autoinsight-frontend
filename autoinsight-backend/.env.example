# ── Application ───────────────────────────────
APP_NAME=AutoInsight ZA
PORT=8765

# ── Database (PostgreSQL) ──────────────────────
# Render provides this automatically as DATABASE_URL
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/autoinsight_db

# ── JWT ────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_IN_PRODUCTION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS / Frontend ────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://symphonious-palmier-e70423.netlify.app,http://localhost:3000

# ── Seeded default users ───────────────────────
SEED_SUPER_ADMIN_EMAIL=superadmin@example.com
SEED_SUPER_ADMIN_PASSWORD=SuperAdmin123!
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin123!
SEED_CLIENT_EMAIL=client@example.com
SEED_CLIENT_PASSWORD=Client123!
